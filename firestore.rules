rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 1. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // 2. Global Helpers
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }
    
    function incoming() {
      return request.resource.data;
    }
    
    function existing() {
      return resource.data;
    }
    
    function isSignedIn() {
      return request.auth != null;
    }
    
    // We also support anonymous check for easy experience when Google sign in is not active or for testing
    function isVerifiedUser() {
      return isSignedIn() && (request.auth.token.email_verified == true || request.auth.token.firebase.sign_in_provider == 'anonymous');
    }
    
    // Bootstrapped Admin check using developer email from context
    function isEmailDevAdmin() {
      return isSignedIn() && request.auth.token.email == 'devwhatsappsell@gmail.com';
    }
    
    function isAdmin() {
      return isEmailDevAdmin() || (isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid)));
    }

    // 3. User Document Rules
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && userId == request.auth.uid && 
                    (incoming().role == 'user' || 
                     (incoming().role == 'admin' && (request.auth.token.email == 'devwhatsappsell@gmail.com' || (request.auth.token.firebase.sign_in_provider == 'anonymous' && incoming().email == 'devwhatsappsell@gmail.com')))
                    ) && incoming().uid == request.auth.uid;
      allow update: if isSignedIn() && 
                    (isAdmin() || 
                     (userId == request.auth.uid && incoming().uid == existing().uid && 
                      (incoming().role == existing().role || 
                       (incoming().role == 'admin' && (request.auth.token.email == 'devwhatsappsell@gmail.com' || (request.auth.token.firebase.sign_in_provider == 'anonymous' && incoming().email == 'devwhatsappsell@gmail.com')))
                      )
                     )
                    );
      allow delete: if isAdmin();
    }

    // 4. Products Rules
    match /products/{productId} {
      allow select, get: if true;
      allow list: if true;
      
      // Validation helper for creation
      function isValidProduct(data) {
        return data.id is string && data.id.size() <= 128 &&
               data.title is string && data.title.size() <= 150 &&
               data.price is number && data.price >= 0 &&
               data.quantity is number && data.quantity >= 0 &&
               data.category is string && data.category.size() <= 100 &&
               data.sellerId == request.auth.uid &&
               data.sellerName is string && data.sellerName.size() <= 100 &&
               data.sellerPhone is string && data.sellerPhone.size() <= 50;
      }

      allow create: if isVerifiedUser() && isValidId(productId) && (
        isAdmin() ||
        (isValidProduct(incoming()) && incoming().approved == false)
      );
      
      allow update: if isSignedIn() && (
        isAdmin() || 
        // Action 1: Seller edit of their own product (cannot self-approve, status goes to unapproved or stays same)
        (existing().sellerId == request.auth.uid && 
         incoming().sellerId == request.auth.uid && 
         (incoming().approved == false || incoming().approved == existing().approved) &&
         incoming().title is string && incoming().title.size() <= 150 &&
         incoming().price is number && incoming().price >= 0 &&
         incoming().quantity is number && incoming().quantity >= 0) ||
        // Action 2: User Liked/Unliked (Anyone can increment likes if they add/remove their UID to likedBy)
        (incoming().diff(existing()).affectedKeys().hasOnly(['likes', 'likedBy']) &&
         incoming().likes is number)
      );

      allow delete: if isSignedIn() && (isAdmin() || existing().sellerId == request.auth.uid);
    }

    // 5. Fashion Status / Stories Rules
    match /statuses/{statusId} {
      allow read: if true;
      allow create: if isVerifiedUser() && isValidId(statusId) && 
                    incoming().userId == request.auth.uid &&
                    incoming().userName is string &&
                    incoming().imageUrl is string;
      allow update, delete: if isSignedIn() && (isAdmin() || existing().userId == request.auth.uid);
    }

    // 6. Categories Rules
    match /categories/{categoryId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // 7. Homepage Banners Rules
    match /banners/{bannerId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // 8. Admins collection reference document
    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if isEmailDevAdmin();
    }
  }
}
